FROM maven:3.9.8-eclipse-temurin-21-alpine AS builder
ARG OPERATION_API_APP_NAME
ARG OPERATION_API_SERVER_PORT
ARG DATABASE_HOSTNAME
ARG DATABASE_HOST_PORT
ARG OPERATION_API_DB
ARG DATABASE_ROOT_USER
ARG DATABASE_ROOT_PWD
ARG SERVICE_REGISTRY_APPLICATION_NAME
ARG SERVICE_REGISTRY_SERVER_PORT
ARG JWT_ISSUER
ARG KEYCLOAK_BACKEND_GATEWAY_CLIENT_ID
ARG OPERATION_TOPIC1_NAME
ARG OPERATION_TOPIC2_NAME
ARG KAFKA_TOPIC_RETENTION_DURATION
ARG KAFKA_TOPIC_RETENTION_SIZE
ARG KAFKA_TOPIC_RETENTION_CLEANUP_POLICY

ENV OPERATION_API_APP_NAME=${OPERATION_API_APP_NAME}
ENV OPERATION_API_SERVER_PORT=${OPERATION_API_SERVER_PORT}
ENV DATABASE_HOSTNAME=${DATABASE_HOSTNAME}
ENV DATABASE_HOST_PORT=${DATABASE_HOST_PORT}
ENV OPERATION_API_DB=${OPERATION_API_DB}
ENV DATABASE_ROOT_USER=${DATABASE_ROOT_USER}
ENV DATABASE_ROOT_PWD=${DATABASE_ROOT_PWD}
ENV SERVICE_REGISTRY_APPLICATION_NAME=${SERVICE_REGISTRY_APPLICATION_NAME}
ENV SERVICE_REGISTRY_SERVER_PORT=${SERVICE_REGISTRY_SERVER_PORT}
ENV JWT_ISSUER=${JWT_ISSUER}
ENV KEYCLOAK_BACKEND_GATEWAY_CLIENT_ID=${KEYCLOAK_BACKEND_GATEWAY_CLIENT_ID}
ENV OPERATION_TOPIC1_NAME=${OPERATION_TOPIC1_NAME}
ENV OPERATION_TOPIC2_NAME=${OPERATION_TOPIC2_NAME}
ENV KAFKA_TOPIC_RETENTION_DURATION=${KAFKA_TOPIC_RETENTION_DURATION}
ENV KAFKA_TOPIC_RETENTION_SIZE=${KAFKA_TOPIC_RETENTION_SIZE}
ENV KAFKA_TOPIC_RETENTION_CLEANUP_POLICY=${KAFKA_TOPIC_RETENTION_CLEANUP_POLICY}

WORKDIR /build/
COPY pom.xml /build/
COPY src /build/src
RUN mvn package -DskipTest
WORKDIR /build/target/
RUN java -Djarmode=layertools -jar exalt-hexagonal-archi-kafka-keycloak-bs-ms-operation-api.jar extract

FROM maven:3.9.8-eclipse-temurin-21-alpine AS final
COPY --from=builder /build/target/dependencies/ ./
COPY --from=builder /build/target/spring-boot-loader/ ./
COPY --from=builder /build/target/snapshot-dependencies/ ./
COPY --from=builder /build/target/application/ ./

EXPOSE ${OPERATION_API_SERVER_PORT}

ENTRYPOINT ["java", "org.springframework.boot.loader.launch.JarLauncher"]